profile main {
  output "Lenovo Group Limited L27m-30 UPB67FNK" mode 1920x1080@74.973Hz position 0,0
  output eDP-1 mode 1920x1080@60Hz position 1920,0
  exec pkill waybar || true; sleep 1; waybar -c "$HOME/.config/waybar/rcm/main.jsonc" -s "$HOME/.config/waybar/rcm/style.css"
}

profile laptop {
  output eDP-1 mode 1920x1080@60Hz position 0,0
  exec pkill waybar || true; sleep 1; waybar -c "$HOME/.config/waybar/rcm/second.jsonc" -s "$HOME/.config/waybar/rcm/style.css"
}
