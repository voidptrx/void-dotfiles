auto-reload yes
browser "librewolf"
external-url-viewer "urlscan -dc -r 'librewolf {}'"

bind-key j down
bind-key k up
bind-key j next        articlelist
bind-key k prev        articlelist
bind-key J next-feed   articlelist
bind-key K prev-feed   articlelist
bind-key G end
bind-key g home
bind-key d pagedown
bind-key u pageup
bind-key o open-in-browser
bind-key h quit
bind-key a toggle-article-read
bind-key n next-unread
bind-key N prev-unread
bind-key D pb-download
bind-key U show-urls
bind-key x pb-delete

macro v set browser "setsid -f mpv" ; open-in-browser ; set browser linkhandler
macro w set browser "librewolf"     ; open-in-browser ; set browser linkhandler

color listnormal cyan default
color listfocus black yellow standout bold
color listnormal_unread blue default
color listfocus_unread yellow default bold
color info red black bold
color article white default bold

highlight article "^(Title):.*"               yellow  default  bold
highlight article "^(Feed|Author):.*"         cyan    default  bold
highlight article "^(Link):.*"                blue    default  underline
highlight article "^(Date):.*"                magenta default  bold
highlight article "https?://[^ ]+"            red     default  underline
highlight article "\[[0-9]+\]"                green   default  bold
